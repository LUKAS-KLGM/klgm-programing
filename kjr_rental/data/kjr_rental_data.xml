<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Service-Produkte für Rechnungszeilen (Steuer-/Kontenfindung) -->
        <record id="product_rental_fee" model="product.product">
            <field name="name">Verleihgebühr</field>
            <field name="type">service</field>
            <field name="list_price">0.0</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="False"/>
        </record>
        <record id="product_rental_deposit" model="product.product">
            <field name="name">Kaution</field>
            <field name="type">service</field>
            <field name="list_price">0.0</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="False"/>
        </record>

        <!-- Konfigurierbare Schalter (Systemparameter) -->
        <record id="param_reserve_draft" model="ir.config_parameter">
            <field name="key">kjr_rental.reserve_draft</field>
            <field name="value">False</field>
        </record>
        <record id="param_auto_invoice_on_return" model="ir.config_parameter">
            <field name="key">kjr_rental.auto_invoice_on_return</field>
            <field name="value">False</field>
        </record>

        <record id="item_bus" model="kjr.rental.item">
            <field name="name">9-Sitzer Bus</field><field name="category">vehicle</field>
            <field name="location">sonthofen</field><field name="quantity_total">1</field>
            <field name="price_per_day">60.0</field><field name="price_member_per_day">40.0</field>
            <field name="deposit">300.0</field><field name="icon">fa-bus</field>
        </record>
        <record id="item_tent" model="kjr.rental.item">
            <field name="name">Gruppenzelt (10 Pers.)</field><field name="category">tent</field>
            <field name="location">sonthofen</field><field name="quantity_total">4</field>
            <field name="price_per_day">15.0</field><field name="price_member_per_day">8.0</field>
            <field name="deposit">50.0</field><field name="icon">fa-home</field>
        </record>
        <record id="item_pa" model="kjr.rental.item">
            <field name="name">PA-Anlage</field><field name="category">tech</field>
            <field name="location">immenstadt</field><field name="quantity_total">2</field>
            <field name="price_per_day">25.0</field><field name="price_member_per_day">15.0</field>
            <field name="deposit">100.0</field><field name="icon">fa-volume-up</field>
        </record>
        <record id="item_balls" model="kjr.rental.item">
            <field name="name">Sportgeräte-Set</field><field name="category">sport</field>
            <field name="location">oberstdorf</field><field name="quantity_total">6</field>
            <field name="price_per_day">5.0</field><field name="price_member_per_day">2.0</field>
            <field name="deposit">20.0</field><field name="icon">fa-futbol-o</field>
        </record>
        <record id="item_kitchen" model="kjr.rental.item">
            <field name="name">Feldküche</field><field name="category">kitchen</field>
            <field name="location">sonthofen</field><field name="quantity_total">2</field>
            <field name="price_per_day">20.0</field><field name="price_member_per_day">12.0</field>
            <field name="deposit">80.0</field><field name="icon">fa-cutlery</field>
        </record>
        <record id="item_games" model="kjr.rental.item">
            <field name="name">Großspielgeräte (Kubb, Twister XXL)</field><field name="category">games</field>
            <field name="location">immenstadt</field><field name="quantity_total">5</field>
            <field name="price_per_day">8.0</field><field name="price_member_per_day">4.0</field>
            <field name="deposit">30.0</field><field name="icon">fa-puzzle-piece</field>
        </record>
    </data>
</odoo>
