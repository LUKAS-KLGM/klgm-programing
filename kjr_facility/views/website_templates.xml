<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Website-Menüeintrag -->
    <data noupdate="1">
        <record id="menu_kjr_einrichtungen" model="website.menu">
            <field name="name">Einrichtungen</field>
            <field name="url">/kjr/einrichtungen</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">62</field>
            <field name="website_id" ref="website.default_website"/>
        </record>
    </data>

    <!-- ── Öffentlich: Einrichtungsliste ──────────────────────────────── -->
    <template id="website_facility_list" name="KJR Einrichtungen">
        <t t-call="website.layout">
            <div id="wrap" class="container mt-4 mb-5">
                <h1 class="mb-2">Unsere Einrichtungen</h1>
                <p class="text-muted mb-4">Jugendhaus Diepolz und Jugendzeltplatz NiSo – für Gruppen buchbar.</p>
                <div class="row">
                    <t t-foreach="facilities" t-as="facility">
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm kjr-facility-card">
                                <img t-if="facility.image_1920" class="card-img-top"
                                     t-attf-src="/web/image/kjr.facility/#{facility.id}/image_1920"
                                     style="height:200px;object-fit:cover;" alt="Bild"/>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title"><t t-esc="facility.name"/></h5>
                                    <p class="card-text text-muted flex-grow-1"><t t-esc="facility.description_short"/></p>
                                    <div class="small text-muted mb-2">
                                        <i class="fa fa-map-marker me-1"/><t t-esc="facility.city"/>
                                        · <i class="fa fa-bed me-1"/><t t-esc="facility.bed_total"/> Betten
                                        · max. <t t-esc="facility.capacity"/> Pers.
                                    </div>
                                    <a t-attf-href="/kjr/einrichtung/#{facility.id}" class="btn btn-primary mt-auto">Details &amp; Anfrage</a>
                                </div>
                            </div>
                        </div>
                    </t>
                    <t t-if="not facilities">
                        <div class="col-12"><div class="alert alert-info">Aktuell sind keine Einrichtungen veröffentlicht.</div></div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- ── Öffentlich: Einrichtungsdetail ─────────────────────────────── -->
    <template id="website_facility_detail" name="KJR Einrichtung Detail">
        <t t-call="website.layout">
            <div id="wrap" class="container mt-4 mb-5">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/kjr/einrichtungen">Einrichtungen</a></li>
                        <li class="breadcrumb-item active"><t t-esc="facility.name"/></li>
                    </ol>
                </nav>
                <div class="row">
                    <div class="col-lg-7">
                        <img t-if="facility.image_1920" class="img-fluid rounded mb-3"
                             t-attf-src="/web/image/kjr.facility/#{facility.id}/image_1920" alt="Bild"/>
                        <h1><t t-esc="facility.name"/></h1>
                        <p class="text-muted"><t t-esc="facility.description_short"/></p>
                        <div t-field="facility.description"/>
                    </div>
                    <div class="col-lg-5">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <h5>Eckdaten</h5>
                                <ul class="list-unstyled">
                                    <li><i class="fa fa-map-marker me-2"/><t t-esc="facility.city"/></li>
                                    <li><i class="fa fa-users me-2"/>max. <t t-esc="facility.capacity"/> Personen</li>
                                    <li><i class="fa fa-bed me-2"/><t t-esc="facility.bed_total"/> Betten</li>
                                </ul>
                                <t t-if="facility.equipment_ids">
                                    <h6 class="mt-3">Ausstattung</h6>
                                    <div class="d-flex flex-wrap gap-2">
                                        <t t-foreach="facility.equipment_ids" t-as="eq">
                                            <span class="badge bg-light text-dark border">
                                                <i t-if="eq.icon" t-attf-class="fa #{eq.icon} me-1"/><t t-esc="eq.name"/>
                                            </span>
                                        </t>
                                    </div>
                                </t>
                                <a t-attf-href="/kjr/einrichtung/#{facility.id}/anfrage"
                                   class="btn btn-primary w-100 mt-3">Buchung anfragen</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ── Buchungsanfrage (Login erforderlich) ───────────────────────── -->
    <template id="website_facility_request" name="KJR Buchungsanfrage">
        <t t-call="website.layout">
            <div id="wrap" class="container mt-4 mb-5">
                <h1 class="mb-3">Buchungsanfrage – <t t-esc="facility.name"/></h1>
                <t t-if="errors">
                    <div class="alert alert-danger"><ul class="mb-0">
                        <t t-foreach="errors.values()" t-as="err"><li><t t-esc="err"/></li></t>
                    </ul></div>
                </t>
                <form method="post" t-attf-action="/kjr/einrichtung/#{facility.id}/anfrage">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Anreise *</label>
                            <input type="date" name="check_in" class="form-control"
                                   t-att-value="values.get('check_in','')" required="required"/>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Abreise *</label>
                            <input type="date" name="check_out" class="form-control"
                                   t-att-value="values.get('check_out','')" required="required"/>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Teilnehmer *</label>
                            <input type="number" name="participant_count" class="form-control" min="1"
                                   t-att-value="values.get('participant_count','')" required="required"/>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Betreuer</label>
                            <input type="number" name="leader_count" class="form-control" min="0"
                                   t-att-value="values.get('leader_count','')"/>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Verpflegung</label>
                            <select name="meal_option" class="form-select">
                                <option value="none">Selbstverpflegung</option>
                                <option value="breakfast">Frühstück</option>
                                <option value="half">Halbpension</option>
                                <option value="full">Vollpension</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Gruppenbezeichnung</label>
                            <input type="text" name="group_name" class="form-control"
                                   t-att-value="values.get('group_name','')"/>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">E-Mail</label>
                            <input type="email" name="contact_email" class="form-control"
                                   t-att-value="values.get('contact_email','')"/>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Telefon</label>
                            <input type="tel" name="contact_phone" class="form-control"
                                   t-att-value="values.get('contact_phone','')"/>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label">Anmerkungen</label>
                            <textarea name="note" class="form-control" rows="3"
                                      t-esc="values.get('note','')"/>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fa fa-paper-plane me-1"/>Anfrage senden
                    </button>
                    <a t-attf-href="/kjr/einrichtung/#{facility.id}" class="btn btn-outline-secondary btn-lg">Abbrechen</a>
                </form>
            </div>
        </t>
    </template>

    <!-- ── Portal: Home-Eintrag ───────────────────────────────────────── -->
    <template id="portal_my_home_kjr_facility" name="Portal: Einrichtungsbuchungen"
              inherit_id="portal.portal_my_home" customize_show="True" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Meine Einrichtungsbuchungen</t>
                <t t-set="url" t-value="'/my/einrichtungsbuchungen'"/>
                <t t-set="placeholder_count" t-value="'kjr_booking_count'"/>
            </t>
        </xpath>
    </template>

    <!-- ── Portal: Buchungsliste ──────────────────────────────────────── -->
    <template id="portal_my_bookings" name="Meine Einrichtungsbuchungen">
        <t t-call="portal.portal_layout">
            <t t-if="not bookings">
                <div class="alert alert-info mt-3">Noch keine Buchungen vorhanden.</div>
            </t>
            <t t-if="bookings">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr>
                            <th>Nummer</th><th>Einrichtung</th><th>Anreise</th><th>Abreise</th>
                            <th>Personen</th><th>Status</th>
                        </tr></thead>
                        <tbody>
                            <t t-foreach="bookings" t-as="bk">
                                <tr>
                                    <td><a t-att-href="bk.access_url"><t t-esc="bk.name"/></a></td>
                                    <td><t t-esc="bk.facility_id.name"/></td>
                                    <td><span t-field="bk.check_in" t-options='{"widget":"date"}'/></td>
                                    <td><span t-field="bk.check_out" t-options='{"widget":"date"}'/></td>
                                    <td><t t-esc="bk.participant_count"/></td>
                                    <td><span class="badge text-bg-secondary"><t t-esc="dict(bk._fields['state'].selection).get(bk.state)"/></span></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
                <div t-if="pager" class="o_portal_pager text-center">
                    <t t-call="portal.pager"/>
                </div>
            </t>
        </t>
    </template>

    <!-- ── Portal: Buchungsdetail ─────────────────────────────────────── -->
    <template id="portal_booking_detail" name="Buchungsdetail">
        <t t-call="portal.portal_layout">
            <div class="row mt-3">
                <div class="col-lg-9">
                    <div class="card mb-3">
                        <div class="card-header bg-primary text-white">
                            <h4 class="mb-0">Buchung <t t-esc="booking.name"/></h4>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-4">Einrichtung</dt><dd class="col-8"><t t-esc="booking.facility_id.name"/></dd>
                                <dt class="col-4">Anreise</dt><dd class="col-8"><span t-field="booking.check_in" t-options='{"widget":"date"}'/></dd>
                                <dt class="col-4">Abreise</dt><dd class="col-8"><span t-field="booking.check_out" t-options='{"widget":"date"}'/></dd>
                                <dt class="col-4">Personen</dt><dd class="col-8"><t t-esc="booking.participant_count"/> (+ <t t-esc="booking.leader_count"/> Betreuer)</dd>
                                <dt class="col-4">Verpflegung</dt><dd class="col-8"><t t-esc="dict(booking._fields['meal_option'].selection).get(booking.meal_option)"/></dd>
                                <dt class="col-4">Gesamt (brutto)</dt><dd class="col-8"><t t-esc="'%.2f €' % booking.amount_total"/></dd>
                                <dt class="col-4">Status</dt><dd class="col-8"><span class="badge text-bg-secondary"><t t-esc="dict(booking._fields['state'].selection).get(booking.state)"/></span></dd>
                            </dl>
                        </div>
                    </div>
                    <div class="mt-3">
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="booking"/>
                        </t>
                    </div>
                </div>
                <div class="col-lg-3">
                    <div class="card"><div class="list-group list-group-flush">
                        <a href="/my/einrichtungsbuchungen" class="list-group-item list-group-item-action">
                            <i class="fa fa-arrow-left me-1"/>Zur Übersicht</a>
                    </div></div>
                </div>
            </div>
        </t>
    </template>

</odoo>
