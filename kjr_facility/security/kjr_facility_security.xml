<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="privilege_kjr_facility" model="res.groups.privilege">
            <field name="name">KJR Einrichtungen</field>
        </record>

        <record id="group_kjr_facility_user" model="res.groups">
            <field name="name">Sachbearbeiter Einrichtungen</field>
            <field name="privilege_id" ref="privilege_kjr_facility"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_kjr_facility_manager" model="res.groups">
            <field name="name">Administrator Einrichtungen</field>
            <field name="privilege_id" ref="privilege_kjr_facility"/>
            <field name="implied_ids" eval="[(4, ref('group_kjr_facility_user'))]"/>
        </record>

        <!-- ── Record Rules: Buchungen ───────────────────────────────────── -->

        <record id="rule_kjr_booking_portal_own" model="ir.rule">
            <field name="name">KJR Einrichtung: Portal-User sieht nur eigene Buchungen</field>
            <field name="model_id" ref="model_kjr_facility_booking"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_kjr_booking_user_all" model="ir.rule">
            <field name="name">KJR Einrichtung: Sachbearbeiter sieht alle Buchungen</field>
            <field name="model_id" ref="model_kjr_facility_booking"/>
            <field name="groups" eval="[(4, ref('group_kjr_facility_user'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Einrichtungen: Portal sieht nur veröffentlichte -->
        <record id="rule_kjr_facility_portal_published" model="ir.rule">
            <field name="name">KJR Einrichtung: Portal-User sieht nur veröffentlichte Einrichtungen</field>
            <field name="model_id" ref="model_kjr_facility"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('website_published', '=', True)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Mehrmandanten-Trennung -->
        <record id="rule_kjr_booking_company" model="ir.rule">
            <field name="name">KJR Einrichtung: Buchung je Gesellschaft</field>
            <field name="model_id" ref="model_kjr_facility_booking"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
