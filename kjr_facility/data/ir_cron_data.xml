<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_kjr_booking_reminder" model="ir.cron">
            <field name="name">KJR Einrichtung: Anreise-Erinnerung</field>
            <field name="model_id" ref="model_kjr_facility_booking"/>
            <field name="state">code</field>
            <field name="code">model._cron_booking_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cron_kjr_contract_followup" model="ir.cron">
            <field name="name">KJR Einrichtung: Vertrags-Nachfass</field>
            <field name="model_id" ref="model_kjr_facility_booking"/>
            <field name="state">code</field>
            <field name="code">model._cron_contract_followup()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cron_kjr_deposit_overdue" model="ir.cron">
            <field name="name">KJR Einrichtung: Anzahlung überfällig</field>
            <field name="model_id" ref="model_kjr_facility_booking"/>
            <field name="state">code</field>
            <field name="code">model._cron_deposit_overdue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cron_kjr_reservation_expiry" model="ir.cron">
            <field name="name">KJR Einrichtung: Reservierung abgelaufen</field>
            <field name="model_id" ref="model_kjr_facility_booking"/>
            <field name="state">code</field>
            <field name="code">model._cron_reservation_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
