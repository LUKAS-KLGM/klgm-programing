<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kjr_juleica_list" model="ir.ui.view">
        <field name="name">kjr.juleica.list</field>
        <field name="model">kjr.juleica</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'expired'" decoration-warning="state == 'expiring'">
                <field name="partner_id"/>
                <field name="organization_id"/>
                <field name="card_number"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="state" widget="badge" decoration-success="state == 'valid'" decoration-warning="state == 'expiring'" decoration-danger="state == 'expired'"/>
            </list>
        </field>
    </record>
    <record id="view_kjr_juleica_form" model="ir.ui.view">
        <field name="name">kjr.juleica.form</field>
        <field name="model">kjr.juleica</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_renew" string="Verlängern" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Karteninhaber">
                            <field name="partner_id"/>
                            <field name="organization_id"/>
                            <field name="card_number"/>
                        </group>
                        <group string="Gültigkeit">
                            <field name="issue_date"/>
                            <field name="validity_years"/>
                            <field name="expiry_date"/>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Ausbildung/Schulung">
                            <field name="training_date"/>
                            <field name="training_hours_presence"/>
                            <field name="training_hours_online"/>
                            <field name="training_hours" readonly="1"/>
                        </group>
                        <group string="Erste Hilfe">
                            <field name="eh_date"/>
                            <field name="eh_valid_years"/>
                            <field name="eh_valid_until" readonly="1"/>
                            <field name="eh_ok" readonly="1"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Bemerkungen..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_kjr_juleica" model="ir.actions.act_window">
        <field name="name">Juleica-Karten</field>
        <field name="res_model">kjr.juleica</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
