<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kjr_assembly_list" model="ir.ui.view">
        <field name="name">kjr.assembly.list</field>
        <field name="model">kjr.assembly</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="location"/>
                <field name="attendee_count" string="Anwesend"/>
                <field name="decision_count" string="Beschlüsse"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_kjr_assembly_form" model="ir.ui.view">
        <field name="name">kjr.assembly.form</field>
        <field name="model">kjr.assembly</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_invite" string="Einladen" type="object" invisible="state != 'draft'"/>
                    <button name="action_done" string="Durchgeführt" type="object" class="btn-primary" invisible="state != 'invited'"/>
                    <button name="action_cancel" string="Absagen" type="object" invisible="state in ('done','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,invited,done"/>
                </header>
                <sheet>
                    <group>
                        <group><field name="name"/><field name="date"/><field name="location"/></group>
                        <group>
                            <field name="eligible_member_count" readonly="1"/>
                            <field name="invited_count" readonly="1"/>
                            <field name="attendee_count" readonly="1"/>
                            <field name="is_repeat_session"/>
                            <field name="quorum_reached" readonly="1"/>
                            <field name="decision_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tagesordnung"><field name="agenda" nolabel="1"/></page>
                        <page string="Eingeladene Verbände"><field name="invited_member_ids" nolabel="1"/></page>
                        <page string="Anwesenheit"><field name="attendee_ids" nolabel="1"/></page>
                        <page string="Beschlüsse">
                            <field name="decision_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="vote_yes"/>
                                    <field name="vote_no"/>
                                    <field name="vote_abstain"/>
                                    <field name="result"/>
                                </list>
                            </field>
                        </page>
                        <page string="Protokoll"><field name="protocol" nolabel="1"/></page>
                    </notebook>
                    <field name="note" placeholder="Anmerkungen..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_kjr_assembly" model="ir.actions.act_window">
        <field name="name">Vollversammlungen</field>
        <field name="res_model">kjr.assembly</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
