<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kjr_volunteer_log_list" model="ir.ui.view">
        <field name="name">kjr.volunteer.log.list</field>
        <field name="model">kjr.volunteer.log</field>
        <field name="arch" type="xml">
            <list string="Ehrenamtsstunden" editable="bottom" sample="1">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="category"/>
                <field name="description" optional="show"/>
                <field name="organization_id" optional="hide"/>
                <field name="application_id" optional="hide"/>
                <field name="hours" sum="Summe Stunden"/>
            </list>
        </field>
    </record>

    <record id="view_kjr_volunteer_log_form" model="ir.ui.view">
        <field name="name">kjr.volunteer.log.form</field>
        <field name="model">kjr.volunteer.log</field>
        <field name="arch" type="xml">
            <form string="Ehrenamtsstunden-Eintrag">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="date"/>
                            <field name="hours"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="organization_id"/>
                            <field name="application_id"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Kurze Beschreibung der Tätigkeit..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_kjr_volunteer_log_search" model="ir.ui.view">
        <field name="name">kjr.volunteer.log.search</field>
        <field name="model">kjr.volunteer.log</field>
        <field name="arch" type="xml">
            <search string="Ehrenamtsstunden">
                <field name="partner_id"/>
                <field name="organization_id"/>
                <field name="category"/>
                <filter name="filter_this_year" string="Dieses Jahr"
                        domain="[('date', '&gt;=', time.strftime('%Y-01-01'))]"/>
                <separator/>
                <filter name="group_partner" string="Ehrenamtliche/r" context="{'group_by': 'partner_id'}"/>
                <filter name="group_category" string="Tätigkeit" context="{'group_by': 'category'}"/>
                <filter name="group_org" string="Verband" context="{'group_by': 'organization_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_kjr_volunteer_log" model="ir.actions.act_window">
        <field name="name">Ehrenamtsstunden</field>
        <field name="res_model">kjr.volunteer.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_kjr_volunteer_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Erste Ehrenamtsstunden erfassen</p>
            <p>Erfasste Stunden fließen automatisch in den Ehrenamtsnachweis (PDF) der jeweiligen Person ein.</p>
        </field>
    </record>

</odoo>
