            <field name="code">4_7</field>
            <field name="sequence">80</field>
            <field name="max_amount">150.0</field>
            <field name="max_per_year">0</field>
            <field name="max_cofinancing_pct">100.0</field>
            <field name="requires_tn_list">False</field>
            <field name="requires_report">False</field>
            <field name="requires_receipt">False</field>
            <field name="requires_other_docs">Formular Neugründung (Beilage KJR OA)</field>
            <field name="description">Einmalige Starthilfe von 150 € für Neugründungen in Orten ohne bestehende Gruppe dieses Verbandes.</field>
        </record>

        <record id="grant_type_4_8a" model="kjr.grant.type">
            <field name="name">Großveranstaltung >100 TN (§ 4.8a)</field>
            <field name="code">4_8a</field>
            <field name="sequence">90</field>
            <field name="rate_per_tn_single">2.0</field>
            <field name="max_amount">400.0</field>
            <field name="max_per_year">0</field>
            <field name="max_cofinancing_pct">50.0</field>
            <field name="min_age">5</field>
            <field name="max_age">27</field>
            <field name="min_participants">101</field>
            <field name="requires_tn_list">True</field>
            <field name="requires_report">True</field>
            <field name="requires_receipt">True</field>
            <field name="description">Tagesveranstaltungen mit mehr als 100 TN, pädagogisch begründbar, Landkreisebene. 2 € pro TN, max. 400 €/Jahr.</field>
        </record>

        <record id="grant_type_4_8b" model="kjr.grant.type">
