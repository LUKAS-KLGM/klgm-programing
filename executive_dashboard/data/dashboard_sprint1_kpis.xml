    <!-- Aufgaben nach Deadline Status -->
    <record id="kpi_cto_chart_deadline" model="executive.dashboard.kpi">
        <field name="dashboard_id" ref="dashboard_cto"/>
        <field name="name">Tasks per Month (Deadline)</field>
        <field name="sequence">107</field>
        <field name="display_type">chart_bar</field>
        <field name="source_type">model</field>
        <field name="model_name">project.task</field>
        <field name="domain">[('date_deadline', '!=', False)]</field>
        <field name="measure_field">id</field>
        <field name="aggregate">count</field>
        <field name="group_by">date_deadline:month</field>
