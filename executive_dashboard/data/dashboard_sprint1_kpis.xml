    <record id="kpi_coo_return_rate" model="executive.dashboard.kpi">
        <field name="dashboard_id" ref="dashboard_coo"/>
        <field name="name">Return Rate</field>
        <field name="description">Anteil der Retouren an den Gesamtlieferungen in Prozent</field>
        <field name="sequence">36</field>
        <field name="display_type">scorecard</field>
        <field name="source_type">formula</field>
        <field name="formula">kpi('_Retouren') / kpi('Lieferungen') * 100 if kpi('Lieferungen') else 0</field>
        <field name="unit">%</field>
        <field name="color">#FFF7ED</field>
        <field name="show_comparison">False</field>
        <field name="target_value">5</field>
        <field name="target_warning">8</field>
        <field name="target_critical">12</field>
    </record>

    <!-- ── CTO: Neue KPIs ── -->

    <!-- Abwesenheitsquote % -->
    <record id="kpi_cto_absence_rate" model="executive.dashboard.kpi">
        <field name="dashboard_id" ref="dashboard_cto"/>
        <field name="name">Absence Rate</field>
        <field name="description">Abwesenheitstage / (Mitarbeiter × 20 Arbeitstage) in Prozent</field>
        <field name="sequence">36</field>
        <field name="display_type">scorecard</field>
        <field name="source_type">formula</field>
        <field name="formula">kpi('Abwesenheitstage') / (kpi('Mitarbeiter') * 20) * 100 if kpi('Mitarbeiter') else 0</field>
        <field name="unit">%</field>
        <field name="color">#FFF7ED</field>
        <field name="show_comparison">False</field>
        <field name="target_value">5</field>
        <field name="target_warning">8</field>
        <field name="target_critical">12</field>
    </record>

    <!-- Abwesenheitstage -->
    <record id="kpi_cto_leave_days" model="executive.dashboard.kpi">
        <field name="dashboard_id" ref="dashboard_cto"/>
        <field name="name">Absence Days</field>
        <field name="description">Genehmigte Abwesenheitstage (Urlaub, Krankheit, etc.) im Zeitraum</field>
        <field name="sequence">35</field>
        <field name="display_type">scorecard</field>
        <field name="source_type">model</field>
