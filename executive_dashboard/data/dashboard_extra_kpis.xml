<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <!-- ══════════════════════════════════════════ -->
    <!-- CEO: Additional Charts                     -->
    <!-- ══════════════════════════════════════════ -->
    <record id="kpi_ceo_chart_orders_month" model="executive.dashboard.kpi">
        <field name="dashboard_id" ref="dashboard_ceo"/>
        <field name="name">Orders per Month</field>
        <field name="sequence">130</field>
        <field name="display_type">chart_line</field>
        <field name="source_type">model</field>
        <field name="model_name">sale.report</field>
        <field name="domain">[('state', 'not in', ['draft', 'cancel', 'sent'])]</field>
        <field name="measure_field">price_subtotal</field>
        <field name="aggregate">count</field>
        <field name="group_by">date:month</field>
        <field name="date_field">date</field>
        <field name="show_comparison">False</field>
    </record>

    <record id="kpi_ceo_chart_leads_team" model="executive.dashboard.kpi">
        <field name="dashboard_id" ref="dashboard_ceo"/>
        <field name="name">Leads by Sales Team</field>
        <field name="sequence">140</field>
        <field name="display_type">chart_doughnut</field>
        <field name="source_type">model</field>
        <field name="model_name">crm.lead</field>
        <field name="domain">[('type', '=', 'opportunity')]</field>
        <field name="measure_field">id</field>
        <field name="aggregate">count</field>
        <field name="group_by">team_id</field>
        <field name="date_field">create_date</field>
        <field name="show_comparison">False</field>
    </record>

    <!-- ══════════════════════════════════════════ -->
    <!-- CEO: Wiederkaufrate (SQL KPI)              -->
    <!-- ══════════════════════════════════════════ -->
    <record id="kpi_ceo_repeat_rate" model="executive.dashboard.kpi">
        <field name="dashboard_id" ref="dashboard_ceo"/>
        <field name="name">Repeat Purchase Rate</field>
        <field name="description">Anteil der Kunden mit mehr als einem Auftrag im Zeitraum</field>
        <field name="sequence">78</field>
        <field name="display_type">scorecard</field>
        <field name="source_type">sql</field>
        <field name="sql_query">SELECT ROUND(
  COUNT(*) FILTER (WHERE cnt > 1) * 100.0 / NULLIF(COUNT(*), 0), 1
)
FROM (
  SELECT partner_id, COUNT(*) cnt
  FROM sale_order
  WHERE state NOT IN ('draft', 'cancel', 'sent')
    AND date_order >= '{date_from}'
    AND date_order &lt;= '{date_to}'
  GROUP BY partner_id
) sub</field>
        <field name="unit">%</field>
        <field name="color">#F0FFF4</field>
        <field name="show_comparison">False</field>
    </record>

