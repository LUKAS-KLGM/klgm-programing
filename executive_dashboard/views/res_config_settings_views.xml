<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.executive.dashboard</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Controlling" string="Controlling" name="executive_dashboard">
                    <block title="Bank Balance" name="bank_settings">
                        <setting string="Bank Journal" help="Which bank account should be displayed as the balance in the dashboard?">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="ed_bank_journal" string="Bank Account" class="col-lg-3"/>
                                    <field name="ed_bank_journal" class="col-lg-4"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="AI Insights" name="ai_settings">
                        <setting string="Smart Analytics" help="Enable AI-powered insights that automatically analyze your KPIs and provide recommendations">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="ed_ai_provider" string="Provider" class="col-lg-3"/>
                                    <field name="ed_ai_provider" class="col-lg-4"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ed_ai_api_key" string="API Key" class="col-lg-3"/>
                                    <field name="ed_ai_api_key" class="col-lg-4" password="True"/>
                                </div>
                                <div class="row mt8">
                                    <div class="col-lg-3"/>
                                    <button name="action_test_ai_key" type="object"
                                            string="Test Connection" class="btn-secondary"
                                            icon="fa-plug"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
