<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard Form View -->
    <record id="view_executive_dashboard_form" model="ir.ui.view">
        <field name="name">executive.dashboard.form</field>
        <field name="model">executive.dashboard</field>
        <field name="arch" type="xml">
            <form string="Executive Dashboard">
                <header>
                    <button name="action_open_dashboard" type="object"
                            string="Dashboard öffnen" class="btn-primary"
                            icon="fa-tachometer"/>
                    <button name="action_send_dashboard_mail" type="object"
                            string="Test-Mail senden" class="btn-secondary"
                            icon="fa-paper-plane"
                            invisible="not mail_enabled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Dashboard Name"/></h1>
                    </div>
                    <group>
                        <group string="Allgemein">
                            <field name="role" string="Rolle"/>
                            <field name="default_period" string="Standard-Zeitraum"/>
                            <field name="comparison_mode" string="Vergleich mit"/>
                            <field name="icon" string="Icon"/>
                        </group>
                        <group string="Erweitert">
                            <field name="sequence" string="Reihenfolge"/>
                            <field name="active" string="Aktiv"/>
                            <field name="auto_refresh" string="Auto-Aktualisierung (Sek.)" help="0 = deaktiviert"/>
                            <field name="company_id" string="Unternehmen" groups="base.group_multi_company"/>
                            <field name="group_ids" widget="many2many_tags" string="Sichtbar für"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Kennzahlen" name="kpis">
                            <field name="kpi_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="Kennzahl"/>
                                    <field name="description" string="Hilfetext" optional="show"/>
                                    <field name="display_type" string="Darstellung"/>
                                    <field name="unit" string="Einheit" optional="show"/>
                                    <field name="target_value" string="Ziel" optional="show"/>
                                    <field name="budget_value" string="Budget" optional="show"/>
                                    <field name="show_comparison" string="Vergleich" optional="show"/>
                                    <field name="color" string="Farbe" widget="color" optional="hide"/>
                                    <field name="width" string="Breite" optional="hide"/>
                                    <field name="source_type" string="Datenquelle" optional="hide"/>
                                    <field name="model_name" string="Odoo-Modell" optional="hide"/>
                                    <field name="measure_field" string="Messfeld" optional="hide"/>
                                    <field name="aggregate" string="Aggregation" optional="hide"/>
                                    <field name="group_by" string="Gruppierung" optional="hide"/>
                                    <field name="formula" string="Formel" optional="hide"/>
                                    <field name="sql_query" string="SQL" optional="hide"/>
                                    <field name="journal_id" string="Bankkonto" optional="hide"/>
                                    <field name="date_field" string="Datumsfeld" optional="hide"/>
                                    <field name="apply_date_filter" string="Zeitfilter" optional="hide"/>
                                    <field name="action_xmlid" string="Drill-Down Aktion" optional="hide"/>
                                    <field name="target_warning" string="Warnschwelle" optional="hide"/>
                                    <field name="target_critical" string="Kritisch" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="E-Mail Report" name="mail">
                            <group>
                                <group>
                                    <field name="mail_enabled" string="Automatischer E-Mail-Versand"/>
                                    <field name="mail_frequency" string="Häufigkeit" invisible="not mail_enabled"/>
                                </group>
                                <group>
                                    <field name="mail_last_sent" string="Zuletzt gesendet" readonly="1"/>
                                </group>
                            </group>
                            <group invisible="not mail_enabled">
                                <field name="mail_recipient_ids" widget="many2many_tags" string="Empfänger"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Dashboard List View -->
    <record id="view_executive_dashboard_list" model="ir.ui.view">
        <field name="name">executive.dashboard.list</field>
        <field name="model">executive.dashboard</field>
        <field name="arch" type="xml">
            <list string="Executive Dashboards">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="role"/>
                <field name="default_period"/>
                <field name="comparison_mode"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="auto_refresh"/>
                <button name="action_open_dashboard" type="object"
                        string="Öffnen" icon="fa-external-link"/>
            </list>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_executive_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard-Konfiguration</field>
        <field name="res_model">executive.dashboard</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
