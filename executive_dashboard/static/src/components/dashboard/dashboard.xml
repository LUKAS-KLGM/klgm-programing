<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="executive_dashboard.Dashboard">
        <div t-att-class="'ed-container ' + themeClass">
            <!-- Header -->
            <div class="ed-header">
                <div class="ed-header-left">
                    <div class="ed-dashboard-picker">
                        <i t-att-class="'fa ' + (activeDashboardIcon || 'fa-tachometer') + ' ed-picker-icon'"/>
                        <select t-on-change="onDashboardChange"
                                class="ed-dashboard-select">
                            <t t-foreach="state.dashboards" t-as="db" t-key="db.id">
                                <option t-att-value="db.id"
                                        t-att-selected="state.activeDashboard === db.id"
                                        t-esc="db.name"/>
                            </t>
                            <option disabled="disabled" value="">──────────</option>
                            <option value="__new__">+ Neu erstellen...</option>
                        </select>
                        <i class="fa fa-chevron-down ed-picker-chevron"/>
                    </div>
                    <button t-att-class="'ed-favorite-btn' + (isFavorite ? ' ed-fav-is-active' : '')"
                            t-on-click="toggleFavorite"
                            t-att-title="isFavorite ? 'Standard-Dashboard entfernen' : 'Als Standard-Dashboard beim Öffnen setzen'">
                        <i t-att-class="isFavorite ? 'fa fa-star' : 'fa fa-star-o'"/>
                    </button>
                </div>
                <div class="ed-header-right">
                    <!-- 1. Icon buttons -->
                    <button class="ed-refresh-btn" t-on-click="toggleInsights" title="AI Insights">
                        <i class="fa fa-lightbulb-o"/>
                    </button>
                    <!-- Config dropdown -->
                    <div class="ed-config-wrap">
                        <button class="ed-refresh-btn" t-on-click.stop="toggleConfigMenu" title="Konfiguration">
                            <i class="fa fa-cog"/>
                        </button>
                        <div t-if="state.showConfigMenu" class="ed-export-menu">
                            <button t-on-click="toggleBuilder" class="ed-export-item" t-if="state.activeDashboard">
                                <i class="fa fa-plus"/> KPI hinzufügen
                            </button>
                            <button t-on-click="toggleTemplates" class="ed-export-item">
                                <i class="fa fa-magic"/> Branchen-Templates
                            </button>
                        </div>
                    </div>
                    <div class="ed-export-wrap">
                        <button class="ed-refresh-btn" t-on-click="toggleExportMenu" title="Exportieren">
                            <i class="fa fa-download"/>
                        </button>
                        <div t-if="state.showExportMenu" class="ed-export-menu">
                            <button t-on-click="exportCSV" class="ed-export-item">
                                <i class="fa fa-file-text-o"/> CSV / Excel
                            </button>
                            <button t-on-click="exportPNG" class="ed-export-item">
                                <i class="fa fa-image"/> Chart als PNG
                            </button>
                        </div>
                    </div>
                    <button class="ed-refresh-btn" t-on-click="toggleFullscreen"
                            t-att-title="state.isFullscreen ? 'Normal' : 'Vollbild'">
                        <i t-att-class="state.isFullscreen ? 'fa fa-compress' : 'fa fa-expand'"/>
                    </button>
                    <button class="ed-refresh-btn" t-on-click="onRefresh" title="Aktualisieren">
                        <i t-att-class="'fa fa-refresh' + (state.loading ? ' fa-spin' : '')"/>
                    </button>
                    <button class="ed-refresh-btn" t-on-click="toggleDark"
                            t-att-title="state.isDark ? 'Light Mode' : 'Dark Mode'">
                        <i t-att-class="state.isDark ? 'fa fa-sun-o' : 'fa fa-moon-o'"/>
                    </button>
                    <!-- 2. Vergleich -->
                    <select t-on-change="(ev) => this.setComparisonMode(ev.target.value)" class="ed-period-select" style="min-width:100px;">
                        <t t-foreach="comparisonOptions" t-as="opt" t-key="opt.value">
                            <option t-att-value="opt.value"
                                    t-att-selected="state.comparisonMode === opt.value"
                                    t-esc="opt.label"/>
                        </t>
                    </select>
                    <!-- 3. Zeitraum -->
                    <select t-on-change="onPeriodChange" class="ed-period-select">
                        <t t-foreach="periodOptions" t-as="opt" t-key="opt.value">
                            <option t-att-value="opt.value"
                                    t-att-selected="opt.value === 'custom' ? state.period.startsWith('custom:') : state.period === opt.value"
                                    t-esc="opt.label"/>
                        </t>
                    </select>
                    <!-- Custom Date Range -->
                    <div t-if="state.showCustomDate" class="ed-custom-date">
                        <input type="date" class="ed-date-input"
                               t-att-value="state.customDateFrom"
                               t-on-change="onCustomDateFrom"/>
                        <span class="ed-date-sep">–</span>
                        <input type="date" class="ed-date-input"
                               t-att-value="state.customDateTo"
                               t-on-change="onCustomDateTo"/>
                        <button class="ed-btn ed-btn-primary ed-btn-sm" t-on-click="applyCustomDate">
                            <i class="fa fa-check"/>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Loading -->
            <div t-if="state.loading" class="ed-loading">
                <div class="ed-spinner"/>
                <span>Daten werden geladen...</span>
            </div>

            <!-- Insights Panel -->
            <div t-if="state.showInsights and !state.loading" class="ed-insights-panel">
                <div class="ed-insights-header">
                    <div class="ed-insights-tabs">
                        <button t-att-class="'ed-insights-tab ' + (state.insightsTab === 'summary' ? 'active' : '')"
                                t-on-click="() => this.switchInsightsTab('summary')">
                            <i class="fa fa-list-ul"/> Zusammenfassung
                        </button>
                        <button t-att-class="'ed-insights-tab ' + (state.insightsTab === 'ai' ? 'active' : '')"
                                t-on-click="() => this.switchInsightsTab('ai')">
                            <i class="fa fa-magic"/> AI Insights
                        </button>
                    </div>
                    <button class="ed-insights-close" t-on-click="toggleInsights">
                        <i class="fa fa-times"/>
                    </button>
                </div>
                <div t-if="state.insightsLoading" class="ed-insights-loading">
                    <div class="ed-spinner"/>
                </div>
                <div t-elif="state.insightsTab === 'ai' and !state.hasAiKey" class="ed-insights-nokey">
                    <i class="fa fa-key fa-2x"/>
                    <p>Hinterlege einen API Key (Anthropic oder OpenAI) in der Dashboard-Konfiguration um AI Insights zu aktivieren.</p>
                </div>
                <div t-else="" class="ed-insights-list">
                    <t t-foreach="activeInsights" t-as="insight" t-key="insight_index">
                        <div t-att-class="'ed-insight ed-insight-' + insight.type">
                            <div class="ed-insight-icon">
                                <i t-att-class="'fa ' + insight.icon"/>
                            </div>
                            <div class="ed-insight-content">
                                <div class="ed-insight-title" t-esc="insight.title"/>
                                <div class="ed-insight-text" t-esc="insight.text"/>
                            </div>
                        </div>
                    </t>
                </div>
            </div>

            <!-- Templates Dialog -->
            <div t-if="state.showTemplates" class="ed-modal-overlay" t-on-click.self="toggleTemplates">
                <div class="ed-modal">
                    <div class="ed-modal-header">
                        <h3><i class="fa fa-magic"/> Branchen-Templates</h3>
                        <button class="ed-modal-close" t-on-click="toggleTemplates">
                            <i class="fa fa-times"/>
                        </button>
                    </div>
                    <div class="ed-modal-body">
                        <p class="ed-modal-hint">Erstelle ein vorkonfiguriertes Dashboard aus einem Branchen-Template:</p>
                        <div class="ed-template-grid">
                            <t t-foreach="state.templates" t-as="tpl" t-key="tpl.key">
                                <div class="ed-template-card" t-on-click="() => this.createFromTemplate(tpl.key)">
                                    <div class="ed-template-icon">
                                        <i t-att-class="'fa fa-2x ' + tpl.icon"/>
                                    </div>
                                    <div class="ed-template-name" t-esc="tpl.name"/>
                                    <div class="ed-template-desc" t-esc="tpl.description"/>
                                    <div class="ed-template-count">
                                        <t t-esc="tpl.kpi_count"/> KPIs
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dashboard Creator Dialog -->
            <div t-if="state.showCreator" class="ed-modal-overlay" t-on-click.self="closeCreator">
                <div class="ed-modal ed-modal-creator">
                    <div class="ed-modal-header">
                        <h3><i class="fa fa-th-large"/> Dashboard erstellen</h3>
                        <button class="ed-modal-close" t-on-click="closeCreator">
                            <i class="fa fa-times"/>
                        </button>
                    </div>
                    <div class="ed-modal-body">
                        <div class="ed-builder-form">
                            <div class="ed-builder-row ed-builder-row-2">
                                <div>
                                    <label>Dashboard-Name *</label>
                                    <input type="text" t-att-value="state.creatorName"
                                           placeholder="z.B. Mein Dashboard"
                                           t-on-input="(ev) => this.state.creatorName = ev.target.value"/>
                                </div>
                                <div>
                                    <label>Icon</label>
                                    <select t-on-change="(ev) => this.state.creatorIcon = ev.target.value">
                                        <t t-foreach="creatorIconOptions" t-as="opt" t-key="opt.value">
                                            <option t-att-value="opt.value"
                                                    t-att-selected="state.creatorIcon === opt.value">
                                                <t t-esc="opt.label"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                            </div>
                            <div class="ed-menu-divider" style="margin:12px 0;"/>
                            <label class="ed-creator-label">KPIs auswählen (<t t-esc="state.selectedKpiIds.size"/> ausgewählt)</label>
                            <div class="ed-creator-kpi-list">
                                <t t-foreach="state.allKpis" t-as="k" t-key="k.id">
                                    <label class="ed-creator-kpi-item"
                                           t-on-click.stop="() => this.toggleKpiSelection(k.id)">
                                        <input type="checkbox" t-att-checked="state.selectedKpiIds.has(k.id)"/>
                                        <div class="ed-creator-kpi-info">
                                            <span class="ed-creator-kpi-name" t-esc="k.name"/>
                                            <span class="ed-creator-kpi-meta">
                                                <t t-esc="k.dashboard_name"/>
                                                <t t-if="k.unit"> · <t t-esc="k.unit"/></t>
                                            </span>
                                        </div>
                                    </label>
                                </t>
                            </div>
                            <div t-if="state.creatorError" class="ed-creator-error">
                                <i class="fa fa-exclamation-circle"/> <t t-esc="state.creatorError"/>
                            </div>
                            <div class="ed-builder-actions">
                                <button class="ed-btn ed-btn-secondary" t-on-click="closeCreator">Abbrechen</button>
                                <button class="ed-btn ed-btn-primary" t-on-click="submitCreator">
                                    <i class="fa fa-check"/> Erstellen
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- KPI Builder Dialog -->
            <div t-if="state.showBuilder" class="ed-modal-overlay" t-on-click.self="toggleBuilder">
                <div class="ed-modal ed-modal-builder">
                    <div class="ed-modal-header">
                        <h3><i class="fa fa-plus-circle"/> KPI erstellen</h3>
                        <button class="ed-modal-close" t-on-click="toggleBuilder">
                            <i class="fa fa-times"/>
                        </button>
                    </div>
                    <div class="ed-modal-body">
                        <div class="ed-builder-form">
                            <div class="ed-builder-row">
                                <label>Name *</label>
                                <input type="text" t-att-value="state.builderForm.name"
                                       t-on-input="(ev) => this.onBuilderFieldChange('name', ev)"
                                       placeholder="z.B. Umsatz pro Monat"/>
                            </div>
                            <div class="ed-builder-row ed-builder-row-2">
                                <div>
                                    <label>Darstellung</label>
                                    <select t-on-change="(ev) => this.onBuilderFieldChange('display_type', ev)">
                                        <t t-foreach="displayTypeOptions" t-as="opt" t-key="opt.value">
                                            <option t-att-value="opt.value"
                                                    t-att-selected="state.builderForm.display_type === opt.value"
                                                    t-esc="opt.label"/>
                                        </t>
                                    </select>
                                </div>
                                <div>
                                    <label>Einheit</label>
                                    <input type="text" t-att-value="state.builderForm.unit"
                                           t-on-input="(ev) => this.onBuilderFieldChange('unit', ev)"
                                           placeholder="EUR, %, Stk."/>
                                </div>
                            </div>
                            <div class="ed-builder-row">
                                <label>Odoo Model *</label>
                                <select t-on-change="(ev) => this.onBuilderModelChange(ev)">
                                    <option value="">— Model wählen —</option>
                                    <t t-foreach="state.builderModels" t-as="m" t-key="m.name">
                                        <option t-att-value="m.name"
                                                t-att-selected="state.builderForm.model_name === m.name"
                                                t-esc="m.label + ' (' + m.name + ')'"/>
                                    </t>
                                </select>
                            </div>
                            <div class="ed-builder-row ed-builder-row-2">
                                <div>
                                    <label>Messfeld *</label>
                                    <select t-on-change="(ev) => this.onBuilderFieldChange('measure_field', ev)">
                                        <option value="">— Feld wählen —</option>
                                        <t t-foreach="state.builderFields" t-as="f" t-key="f.name">
                                            <option t-att-value="f.name"
                                                    t-att-selected="state.builderForm.measure_field === f.name"
                                                    t-esc="f.label"/>
                                        </t>
                                    </select>
                                </div>
                                <div>
                                    <label>Aggregation</label>
                                    <select t-on-change="(ev) => this.onBuilderFieldChange('aggregate', ev)">
                                        <t t-foreach="aggregateOptions" t-as="opt" t-key="opt.value">
                                            <option t-att-value="opt.value"
                                                    t-att-selected="state.builderForm.aggregate === opt.value"
                                                    t-esc="opt.label"/>
                                        </t>
                                    </select>
                                </div>
                            </div>
                            <div class="ed-builder-row ed-builder-row-2">
                                <div>
                                    <label>Datumsfeld</label>
                                    <select t-on-change="(ev) => this.onBuilderFieldChange('date_field', ev)">
                                        <t t-foreach="state.builderDateFields" t-as="f" t-key="f.name">
                                            <option t-att-value="f.name"
                                                    t-att-selected="state.builderForm.date_field === f.name"
                                                    t-esc="f.label"/>
                                        </t>
                                    </select>
                                </div>
                                <div>
                                    <label>Gruppierung</label>
                                    <input type="text" t-att-value="state.builderForm.group_by"
                                           t-on-input="(ev) => this.onBuilderFieldChange('group_by', ev)"
                                           placeholder="z.B. date:month"/>
                                </div>
                            </div>
                            <div class="ed-builder-row ed-builder-row-2">
                                <div>
                                    <label>Zielwert</label>
                                    <input type="number" t-att-value="state.builderForm.target_value"
                                           t-on-input="(ev) => this.onBuilderFieldChange('target_value', ev)"/>
                                </div>
                                <div>
                                    <label>Budget</label>
                                    <input type="number" t-att-value="state.builderForm.budget_value"
                                           t-on-input="(ev) => this.onBuilderFieldChange('budget_value', ev)"/>
                                </div>
                            </div>
                            <div class="ed-builder-row">
                                <label>Domain (optional)</label>
                                <input type="text" t-att-value="state.builderForm.domain"
                                       t-on-input="(ev) => this.onBuilderFieldChange('domain', ev)"
                                       placeholder="[('state', '=', 'posted')]"/>
                            </div>
                            <div class="ed-builder-actions">
                                <button class="ed-btn ed-btn-secondary" t-on-click="toggleBuilder">Abbrechen</button>
                                <button class="ed-btn ed-btn-primary" t-on-click="submitBuilder">
                                    <i class="fa fa-check"/> KPI erstellen
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dashboard Content -->
            <div t-if="!state.loading and state.dashboardData" class="ed-content" t-ref="content">

                <!-- KPI Scorecards (Drag & Drop) -->
                <div class="ed-kpi-grid" t-if="scorecards.length">
                    <t t-foreach="scorecards" t-as="kpi" t-key="kpi.id">
                        <div class="ed-kpi-drag-wrap"
                             draggable="true"
                             t-on-dragstart="(ev) => this.onDragStart('scorecard', kpi.id, ev)"
                             t-on-dragend="(ev) => this.onDragEnd(ev)"
                             t-on-dragover="(ev) => this.onDragOver(ev)"
                             t-on-drop="(ev) => this.onDrop('scorecard', kpi.id, ev)">
                            <KpiCard kpi="kpi" isDark="state.isDark"
                                     activityState="state.activityState"
                                     onDrillDown="(kpi) => this.onDrillDown(kpi)"
                                     onKpiUpdated="() => this.onRefresh()"
                                     onActivityStateChange="(s) => this.setActivityState(s)"/>
                        </div>
                    </t>
                </div>

                <!-- Charts (Drag & Drop) -->
                <div class="ed-chart-grid" t-if="charts.length and state.chartReady">
                    <t t-foreach="charts" t-as="chart" t-key="chart.id">
                        <DashboardChart kpi="chart" isDark="state.isDark"
                                        activityState="state.activityState"
                                        onDrillDown="(kpi) => this.onDrillDown(kpi)"
                                        onKpiUpdated="() => this.onRefresh()"
                                        onActivityStateChange="(s) => this.setActivityState(s)"
                                        onDragStart="(ev) => this.onDragStart('chart', chart.id, ev)"
                                        onDragEnd="(ev) => this.onDragEnd(ev)"
                                        onDragOver="(ev) => this.onDragOver(ev)"
                                        onDrop="(ev) => this.onDrop('chart', chart.id, ev)"/>
                    </t>
                </div>

                <!-- Activity History Hint -->
                <div t-if="!state.hasActivityHistory" class="ed-hint-banner">
                    <i class="fa fa-info-circle"/>
                    Aktivitäts-KPIs zeigen nur geplante Aktivitäten. Installiere das Modul
                    <strong>Partner Activity History</strong> um auch erledigte Anrufe, E-Mails und Meetings auszuwerten.
                </div>
            </div>

            <!-- Empty state -->
            <div t-if="!state.loading and !state.dashboardData and !state.dashboards.length" class="ed-empty">
                <i class="fa fa-tachometer fa-4x"/>
                <h3>Keine Dashboards konfiguriert</h3>
                <p>Erstelle ein Dashboard aus einem Branchen-Template oder gehe zu Konfiguration.</p>
                <button class="ed-btn ed-btn-primary" t-on-click="toggleTemplates">
                    <i class="fa fa-magic"/> Template verwenden
                </button>
            </div>
        </div>
    </t>

</templates>
