<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="rule_dashboard_all_users" model="ir.rule">
        <field name="name">Executive Dashboard: All internal users</field>
        <field name="model_id" ref="model_executive_dashboard"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Multi-Company: Dashboard nur für eigene Company -->
    <record id="rule_dashboard_company" model="ir.rule">
        <field name="name">Executive Dashboard: Multi-Company</field>
        <field name="model_id" ref="model_executive_dashboard"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Notes: Jeder darf lesen, nur eigene löschen (im Controller geprüft) -->
    <record id="rule_note_all_users" model="ir.rule">
        <field name="name">Dashboard KPI Note: All users</field>
        <field name="model_id" ref="model_executive_dashboard_kpi_note"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

</odoo>
