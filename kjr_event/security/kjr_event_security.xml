<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- E4: Gruppe für Kooperationspartner (Portal) -->
    <record id="group_kjr_cooperation_partner" model="res.groups">
        <field name="name">KJR Kooperationspartner</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
        <field name="comment">Externe Kooperationspartner mit Lesezugriff auf die Teilnehmerlisten der ihnen zugeordneten KJR-Veranstaltungen.</field>
    </record>

    <!-- Lesezugriff Kooperationspartner auf zugeordnete Veranstaltungen -->
    <record id="rule_kjr_cooperation_event" model="ir.rule">
        <field name="name">KJR: Kooperationspartner sieht zugeordnete Veranstaltungen</field>
        <field name="model_id" ref="event.model_event_event"/>
        <field name="groups" eval="[(4, ref('group_kjr_cooperation_partner'))]"/>
        <field name="domain_force">['|', ('cooperation_partner_id', '=', user.partner_id.id), ('cooperation_user_ids', 'in', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Lesezugriff Kooperationspartner auf Anmeldungen ihrer Veranstaltungen -->
    <record id="rule_kjr_cooperation_registration" model="ir.rule">
        <field name="name">KJR: Kooperationspartner sieht Teilnehmer/innen zugeordneter Veranstaltungen</field>
        <field name="model_id" ref="event.model_event_registration"/>
        <field name="groups" eval="[(4, ref('group_kjr_cooperation_partner'))]"/>
        <field name="domain_force">['|', ('event_id.cooperation_partner_id', '=', user.partner_id.id), ('event_id.cooperation_user_ids', 'in', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
